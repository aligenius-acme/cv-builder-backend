// AI Resume & CV Customizer - Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Roles Enum
enum UserRole {
  USER       // Individual job seekers
  ADMIN      // Super admin
}

// OAuth Provider Enum
enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}

// User Model
model User {
  id                String            @id @default(uuid())
  email             String            @unique
  passwordHash      String?           // Nullable for OAuth users
  firstName         String?
  lastName          String?
  avatarUrl         String?           // Profile picture from OAuth
  role              UserRole          @default(USER)

  // OAuth fields
  authProvider      AuthProvider      @default(LOCAL)
  providerId        String?           // ID from OAuth provider
  providerData      Json?             // Additional data from provider

  // Resume related
  resumes           Resume[]
  resumeVersions    ResumeVersion[]
  coverLetters      CoverLetter[]

  // Job applications
  jobApplications   JobApplication[]

  // Saved jobs (from job board)
  savedJobs         SavedJob[]

  // Usage tracking
  aiUsageLogs       AIUsageLog[]

  // Subscription plan
  plan                 String            @default("FREE") // "FREE" | "PRO"
  stripeCustomerId     String?           @unique
  stripeSubscriptionId String?           @unique

  // AI Credits (5 lifetime credits for free users)
  aiCredits                  Int               @default(5)
  aiCreditsUsed              Int               @default(0)
  monthlyCreditsRefreshedAt  DateTime?         // last time free user claimed monthly credits

  // Timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  lastLoginAt       DateTime?

  // Email verification
  emailVerified     Boolean           @default(false)
  emailVerifyToken  String?

  // Password reset
  passwordResetToken    String?
  passwordResetExpires  DateTime?

  @@index([email])
  @@index([authProvider, providerId])
}

// Resume Model (Base Resume)
model Resume {
  id                String            @id @default(uuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // File storage
  originalFileName  String
  originalFileUrl   String            // S3 URL
  originalFileKey   String            // S3 Key for deletion

  // Parsed content
  rawText           String            @db.Text
  parsedData        Json              // Structured JSON: summary, experience, skills, education

  // Metadata
  title             String            @default("My Resume")
  isBase            Boolean           @default(true)

  // Photo
  photoUrl          String?           @db.Text

  // Processing status
  parseStatus       String            @default("pending") // pending, processing, completed, failed
  parseError        String?

  // Versions
  versions          ResumeVersion[]

  // Timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
}

// Resume Version (Job-specific tailored versions)
model ResumeVersion {
  id                String            @id @default(uuid())
  resumeId          String
  resume            Resume            @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Version info
  versionNumber     Int

  // Job context
  jobTitle          String
  companyName       String
  jobDescription    String            @db.Text

  // Extracted JD data
  jobData           Json              // required skills, preferred skills, responsibilities, keywords

  // Tailored content
  tailoredData      Json              // Modified resume JSON
  tailoredText      String            @db.Text

  // AI customization details
  changesExplanation String           @db.Text
  matchedKeywords   String[]
  missingKeywords   String[]

  // ATS Score
  atsScore          Int               @default(0)
  atsDetails        Json?             // Detailed ATS analysis

  // Truth Guard warnings
  truthGuardWarnings Json?

  // Template
  templateId        String?

  // Generated files
  pdfFileUrl        String?
  pdfFileKey        String?
  docxFileUrl       String?
  docxFileKey       String?

  // Anonymization (for B2B)
  isAnonymized      Boolean           @default(false)
  anonymizedData    Json?

  // Public sharing
  isPublic          Boolean           @default(false)
  shareToken        String?           @unique
  shareViews        Int               @default(0)
  shareDownloads    Int               @default(0)
  shareAnalytics    ShareAnalytics[]

  // Timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([resumeId, versionNumber])
  @@index([userId])
  @@index([resumeId])
  @@index([shareToken])
}

// Share Analytics for tracking resume views
model ShareAnalytics {
  id              String          @id @default(uuid())
  resumeVersionId String
  resumeVersion   ResumeVersion   @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)

  // Event type
  eventType       String          // 'view' | 'download'

  // Visitor info
  visitorIp       String?
  userAgent       String?
  referer         String?
  country         String?
  city            String?

  // Timestamps
  createdAt       DateTime        @default(now())

  @@index([resumeVersionId])
  @@index([createdAt])
}

// Cover Letter Model
model CoverLetter {
  id                String            @id @default(uuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Context
  resumeVersionId   String?
  jobTitle          String
  companyName       String
  jobDescription    String            @db.Text

  // Generated content
  content           String            @db.Text
  tone              String            @default("professional")

  // Generated files
  pdfFileUrl        String?
  pdfFileKey        String?
  docxFileUrl       String?
  docxFileKey       String?

  // Timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
}

// Resume Template Model
model ResumeTemplate {
  id                String            @id @default(uuid())
  name              String
  description       String?

  // Template configuration
  templateConfig    Json              // Layout, styling, sections config
  previewImageUrl   String?

  // Access control
  isDefault         Boolean           @default(false)
  isPremium         Boolean           @default(false)

  // ATS safety (legacy)
  isAtsSafe         Boolean           @default(true)

  // ============================================================================
  // NEW FIELDS - Enhanced Template System 2026
  // ============================================================================

  // Primary taxonomy
  primaryCategory   String?           // 'ats-professional' | 'tech-startup' | etc.
  designStyle       String?           // 'minimal' | 'modern' | 'bold' | 'traditional'
  pageLength        String?           // 'one-page' | 'standard' | 'cv-length'
  atsCompatibility  String?           // 'ats-safe' | 'ats-friendly' | 'visual-first'

  // Targeting & Discovery
  industryTags      String[]          // ['finance', 'technology', 'healthcare']
  targetRoles       String[]          // ['software-engineer', 'product-manager']
  experienceLevel   String?           // 'entry' | 'mid' | 'senior' | 'executive'
  searchKeywords    String[]          // SEO/search optimization terms

  // Engagement & Analytics
  popularityScore   Int               @default(0)
  isFeatured        Boolean           @default(false)
  supportedFormats  String[]          @default(["pdf", "docx"])
  usageCount        Int               @default(0)

  // Photo support
  photoSupport      Boolean           @default(false)

  // Timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([primaryCategory])
  @@index([designStyle])
  @@index([atsCompatibility])
  @@index([popularityScore])
  @@index([isFeatured])
  @@index([photoSupport])
}

// AI Usage Log (for cost tracking)
model AIUsageLog {
  id                String            @id @default(uuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Request details
  operation         String            // resume_tailor, cover_letter, ats_analysis, etc.
  provider          String            // openai, anthropic, grok
  model             String

  // Token usage
  promptTokens      Int
  completionTokens  Int
  totalTokens       Int

  // Cost tracking
  estimatedCost     Decimal           @db.Decimal(10, 6)

  // Performance
  durationMs        Int

  // Status
  success           Boolean           @default(true)
  errorMessage      String?

  // Timestamps
  createdAt         DateTime          @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Parsing Error Log
model ParsingErrorLog {
  id                String            @id @default(uuid())
  resumeId          String?
  userId            String?

  fileName          String
  fileType          String
  errorMessage      String            @db.Text
  errorStack        String?           @db.Text

  createdAt         DateTime          @default(now())

  @@index([createdAt])
}

// Prompt Version (for AI prompt management)
model PromptVersion {
  id                String            @id @default(uuid())
  name              String            @unique
  version           Int               @default(1)
  promptText        String            @db.Text
  isActive          Boolean           @default(true)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([name, version])
}

// Admin Audit Log
model AuditLog {
  id                String            @id @default(uuid())
  adminId           String
  action            String
  targetType        String            // user, organization, subscription, etc.
  targetId          String?
  details           Json?

  createdAt         DateTime          @default(now())

  @@index([adminId])
  @@index([createdAt])
}

// Job Application Status Enum
enum ApplicationStatus {
  WISHLIST
  APPLIED
  SCREENING
  INTERVIEWING
  OFFER
  REJECTED
  ACCEPTED
  WITHDRAWN
}

// Job Application Model (for Job Tracker)
model JobApplication {
  id                String            @id @default(uuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Job details
  jobTitle          String
  companyName       String
  location          String?
  salary            String?
  jobUrl            String?
  jobDescription    String?           @db.Text

  // Application status
  status            ApplicationStatus @default(WISHLIST)
  statusOrder       Int               @default(0)  // For ordering within a column

  // Key dates
  appliedAt         DateTime?
  deadline          DateTime?

  // Interview tracking
  interviewDate     DateTime?
  interviewType     String?           // phone, video, onsite, technical
  interviewNotes    String?           @db.Text

  // Related documents
  resumeVersionId   String?
  coverLetterId     String?

  // Notes and follow-up
  notes             String?           @db.Text
  contactName       String?
  contactEmail      String?
  nextFollowUp      DateTime?

  // Offer details (if applicable)
  offerAmount       String?
  offerDeadline     DateTime?

  // Metadata
  source            String?           // linkedin, indeed, company_website, referral, etc.
  priority          Int               @default(0)  // 0=normal, 1=high, 2=urgent
  color             String?           // For visual organization

  // Activity log
  activities        JobActivity[]

  // Timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Job Activity Log (for tracking changes)
model JobActivity {
  id                String            @id @default(uuid())
  jobApplicationId  String
  jobApplication    JobApplication    @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  // Activity details
  type              String            // status_change, note_added, interview_scheduled, follow_up, etc.
  description       String
  oldValue          String?
  newValue          String?

  // Timestamps
  createdAt         DateTime          @default(now())

  @@index([jobApplicationId])
  @@index([createdAt])
}

// Saved Job Model (for Job Board)
model SavedJob {
  id                String            @id @default(uuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Job identifiers
  externalJobId     String            // ID from external job board (e.g., Adzuna)
  source            String            @default("Adzuna")

  // Job details (stored as we received them)
  title             String
  company           String
  location          String
  salary            String?
  jobType           String?
  description       String            @db.Text
  url               String

  // Additional metadata
  postedAt          String?           // Relative time from source (e.g., "2 days ago")
  logoUrl           String?

  // User notes
  notes             String?           @db.Text

  // Timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([userId, externalJobId])
  @@index([userId])
  @@index([createdAt])
}

// Affiliate Link Model (skill → course recommendation)
model AffiliateLink {
  id                String   @id @default(uuid())
  skill             String   @unique  // keyword ('python', 'grammarly' for the Grammarly CTA, etc.)
  title             String
  url               String
  provider          String   // 'Udemy' | 'Coursera' | 'LinkedIn Learning' | 'Grammarly'
  isActive          Boolean  @default(true)
  showOnCreditsPage Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([skill])
  @@index([isActive])
  @@index([showOnCreditsPage])
}

// A/B Test Status Enum
enum ABTestStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

// Resume A/B Test Model
model ResumeABTest {
  id                String            @id @default(uuid())
  userId            String

  // Test details
  name              String
  description       String?
  targetJobTitle    String?
  targetCompany     String?

  // Status
  status            ABTestStatus      @default(DRAFT)

  // Variants
  variants          ABTestVariant[]

  // Goal tracking
  goal              String            @default("response_rate")  // response_rate, interview_rate, view_time

  // Test period
  startedAt         DateTime?
  endedAt           DateTime?

  // Results
  winningVariantId  String?

  // Timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
  @@index([status])
}

// A/B Test Variant
model ABTestVariant {
  id                String            @id @default(uuid())
  testId            String
  test              ResumeABTest      @relation(fields: [testId], references: [id], onDelete: Cascade)

  // Variant details
  name              String            // e.g., "Version A", "Version B"
  resumeVersionId   String?           // Link to ResumeVersion if using existing

  // Custom content (if not using resumeVersionId)
  customContent     Json?

  // Tracking
  shareToken        String?           @unique

  // Metrics
  views             Int               @default(0)
  downloads         Int               @default(0)
  applications      Int               @default(0)
  responses         Int               @default(0)
  interviews        Int               @default(0)

  // Calculated metrics
  responseRate      Float             @default(0)

  // Events
  events            ABTestEvent[]

  // Timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([testId])
  @@index([shareToken])
}

// A/B Test Event (for detailed analytics)
model ABTestEvent {
  id                String            @id @default(uuid())
  variantId         String
  variant           ABTestVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // Event type
  eventType         String            // view, download, application_sent, response_received, interview_scheduled

  // Metadata
  metadata          Json?

  // Visitor info
  visitorId         String?
  visitorIp         String?
  userAgent         String?
  country           String?

  // Timestamps
  createdAt         DateTime          @default(now())

  @@index([variantId])
  @@index([eventType])
  @@index([createdAt])
}

// App-wide configuration settings (admin-managed at runtime)
model AppSettings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
