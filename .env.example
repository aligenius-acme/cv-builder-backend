# =============================================================================
# CV Builder — Backend Environment Variables
# -----------------------------------------------------------------------------
# NEVER commit .env to GitHub. This file (.env.example) is safe to commit
# because it contains only placeholder values, not real secrets.
#
# LOCAL SETUP:
#   Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# PRODUCTION:
#   Set these variables directly in the Koyeb dashboard.
#   Do not create a .env file for production.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# Local:      Docker container started with "docker compose up -d"
# Production: Neon connection string (neon.tech)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5444/cv_builder?schema=public

# -----------------------------------------------------------------------------
# Redis
# Local:      Docker container started with "docker compose up -d"
# Production: Upstash Redis (upstash.com)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Authentication — Generate strong secrets, never reuse between environments
# Generate JWT_SECRET:     node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Generate ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('base64').slice(0,32))"
# -----------------------------------------------------------------------------
JWT_SECRET=local-dev-jwt-secret-change-this-do-not-use-in-production
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=local-dev-32char-encryption-key!

# -----------------------------------------------------------------------------
# OpenAI — platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Cloudinary — cloudinary.com/console
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# -----------------------------------------------------------------------------
# SendGrid — app.sendgrid.com/settings/api_keys
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=CV Builder

# -----------------------------------------------------------------------------
# Google OAuth — console.cloud.google.com
# Local redirect:      http://localhost:3000/auth/google/callback
# Production redirect: https://your-backend.koyeb.app/api/auth/google/callback
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# -----------------------------------------------------------------------------
# GitHub OAuth — github.com/settings/developers
# Local redirect:      http://localhost:3000/auth/github/callback
# Production redirect: https://your-backend.koyeb.app/api/auth/github/callback
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

# -----------------------------------------------------------------------------
# Stripe — dashboard.stripe.com (skip if not using payments)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# -----------------------------------------------------------------------------
# Puppeteer — PDF generation
# Local:      Leave blank (uses bundled Chromium)
# Production: /usr/bin/chromium  (set in Koyeb dashboard)
# -----------------------------------------------------------------------------
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
SENTRY_DSN=https://your-key@sentry.io/your-project-id
